DATABASE_URL="file:./dev.db"
TMDB_API_KEY="your_tmdb_api_key_here"

# Authentication (NextAuth.js v5 / Auth.js)
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="your_cryptographically_secure_secret_at_least_32_characters"
# Set to "true" when self-hosting behind a proxy / non-Vercel host.
AUTH_TRUST_HOST="true"

# Default Owner Settings (used to auto-create the owner account on first run
# and by scripts/migrate-user-data.ts). Only the owner can log in and manage content.
APP_OWNER_USERNAME="admin"
APP_OWNER_EMAIL="admin@filmjournal.local"
APP_OWNER_PASSWORD="change_me_before_first_run"
