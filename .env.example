# PostgreSQL (Neon):
# - DATABASE_URL: the POOLED connection string (append `?pgbouncer=true&connection_limit=1`
#   for serverless so each function instance holds a single pooled connection).
# - DIRECT_URL: the DIRECT (non-pooled) connection string — used only by
#   `prisma migrate deploy` and other schema operations.
DATABASE_URL="postgresql://USER:PASSWORD@POOLED_HOST/DATABASE?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require"

# NextAuth (NEXTAUTH_SECRET is required in every environment: `openssl rand -base64 32`)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="GENERATE_A_UNIQUE_RANDOM_SECRET"

# TMDB (https://www.themoviedb.org/settings/api)
TMDB_API_KEY="YOUR_TMDB_API_KEY"

# Initial owner bootstrap (used only until the owner account exists)
APP_OWNER_USERNAME="YOUR_OWNER_USERNAME"
APP_OWNER_PASSWORD="SET_A_STRONG_INITIAL_OWNER_PASSWORD"

# Optional — future integrations (not required today):
# BLOB_READ_WRITE_TOKEN=""   # Vercel Blob, to store avatar uploads instead of data URLs
# KV_REST_API_URL="" KV_REST_API_TOKEN=""   # Vercel KV/Upstash, to replace the DB-backed rate limiter
