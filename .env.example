# PostgreSQL (Neon):
# - DATABASE_URL: conexão com pool; em serverless, limite cada instância a uma conexão.
# - DIRECT_URL: conexão direta, usada apenas por migrations e ajustes no schema.
DATABASE_URL="postgresql://USER:PASSWORD@POOLED_HOST/DATABASE?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require"

# NextAuth (`NEXTAUTH_SECRET` é obrigatório em todos os ambientes)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="GENERATE_A_UNIQUE_RANDOM_SECRET"

# TMDB (https://www.themoviedb.org/settings/api)
TMDB_API_KEY="YOUR_TMDB_API_KEY"

# Dados iniciais do dono, usados somente até a conta ser criada
APP_OWNER_USERNAME="YOUR_OWNER_USERNAME"
APP_OWNER_PASSWORD="SET_A_STRONG_INITIAL_OWNER_PASSWORD"

# Opcionais para integrações futuras:
# BLOB_READ_WRITE_TOKEN=""   # Vercel Blob para armazenar avatares
# KV_REST_API_URL="" KV_REST_API_TOKEN=""   # Vercel KV/Upstash para limitar requisições
