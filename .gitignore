# ── Dependencies ─────────────────────────────────────────────────────
node_modules/

# ── Next.js build ────────────────────────────────────────────────────
.next/
out/

# ── Environment / secrets (NEVER commit these) ───────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
!.env.example

# ── Prisma local database ────────────────────────────────────────────
prisma/*.db
prisma/*.db-journal

# ── Logs & temp ──────────────────────────────────────────────────────
*.log
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/

# ── CSV data exports (personal data, not for version control) ────────
*.csv

# ── Vercel ───────────────────────────────────────────────────────────
.vercel

# Graphify generated output (regenerate with `graphify update .`)
graphify-out/

# Generated assistant tooling (.codex is installed by graphify) and
# machine-specific assistant hook configuration
.codex/
.claude/settings.json
