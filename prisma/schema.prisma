generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Movie {
  id                    String      @id @default(cuid())
  tmdbId                Int?        @unique
  title                 String
  year                  Int?
  releaseDate           DateTime?
  letterboxdUri         String?     @unique
  posterPath            String?
  backdropPath          String?
  preferredPosterPath   String?
  preferredBackdropPath String?
  overview              String?
  tagline               String?
  runtime               Int?
  genres                String?
  directors             String?
  directorId            Int?
  directorName          String?
  cast                  String?
  tmdbRating            Float?
  tmdbVoteCount         Int?
  originalLanguage      String? // ISO 639-1, e.g. "ja"
  countries             String[] // ISO 3166-1, e.g. ["JP"]
  imdbId                String?     @unique
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  logs                  LogEntry[]
  userMovies            UserMovie[]
  genreList             Genre[]
  keywords              Keyword[]

  @@index([title])
  @@index([year])
}

// TMDB genre taxonomy (id is the TMDB genre id). Related many-to-many to Movie
// via genreList; the denormalized Movie.genres string is kept for legacy reads.
model Genre {
  id     Int     @id // TMDB genre id
  name   String
  movies Movie[]
}

// TMDB keyword/tag taxonomy (id is the TMDB keyword id). Used by the themes /
// motifs analysis (see roadmap Phase 5).
model Keyword {
  id     Int     @id // TMDB keyword id
  name   String
  movies Movie[]
}

model User {
  id                  String               @id @default(cuid())
  username            String               @unique
  email               String               @unique
  passwordHash        String
  displayName         String?
  avatarUrl           String?
  bio                 String?
  role                String               @default("USER") // e.g. OWNER, USER
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  userMovies          UserMovie[]
  logs                LogEntry[]
  settings            UserSettings?
  blindSpotDismissals BlindSpotDismissal[]
  gameScores          GameScore[]
}

// Best score per game mode. game is the mode id ("cast" = Guess by Cast);
// source is the round pool ("mine" = the viewer's films, "popular" = TMDB).
model GameScore {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game       String
  source     String
  bestScore  Int
  bestRounds Int
  updatedAt  DateTime @updatedAt

  @@id([userId, game, source])
}

// "Not interested" signals for the blind-spot engine. gapKey is a bucket key
// within the dimension ("1960" for a decade, "JP" for a country, "ja" for a
// language, a TMDB genre id for a genre) or "*" to mute the whole dimension.
model BlindSpotDismissal {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dimension String // "decade" | "country" | "language" | "genre"
  gapKey    String
  createdAt DateTime @default(now())

  @@id([userId, dimension, gapKey])
}

model UserSettings {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme              String   @default("dark") // "system" | "dark" | "light"
  accentColor        String   @default("#f5c518")
  language           String   @default("pt-BR") // "pt-BR" | "en"
  region             String   @default("BR")
  dateFormat         String   @default("dd/MM/yyyy")
  defaultRatingScale Int      @default(5) // 5 | 10
  allowHalfStars     Boolean  @default(true)
  profileVisibility  String   @default("private") // "private" | "public"
  showAdultContent   Boolean  @default(false)
  defaultLandingPage String   @default("/")
  emailNotifications Boolean  @default(false)
  // Last-used roulette filter set ({ source, genres, people, yearFrom, ... }),
  // written by /api/roulette/prefs so a spin setup survives across devices.
  rouletteFilters    Json?
  // First-run onboarding: null = the /welcome flow has not been completed yet.
  // Accounts that already had journal data were backfilled at migration time.
  onboardedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserMovie {
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId          String
  movie            Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  watched          Boolean   @default(false)
  favorite         Boolean   @default(false)
  favoriteRank     Int?
  watchlist        Boolean   @default(false)
  watchlistAddedAt DateTime?
  rating           Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@id([userId, movieId])
  @@unique([userId, favoriteRank])
  @@index([userId])
  @@index([movieId])
  @@index([userId, watched])
  @@index([userId, watchlist, watchlistAddedAt])
  @@index([userId, rating])
}

// Shared-store rate limiting (survives serverless cold starts). Keys are
// namespaced, e.g. "register:{ip}" or "pwd:{userId}".
model RateLimit {
  key     String   @id
  count   Int      @default(1)
  resetAt DateTime

  @@index([resetAt])
}

model LogEntry {
  id         String    @id @default(cuid())
  movieId    String
  movie      Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceKey  String    @unique
  // v2 event identity: movie + effective watch day + same-day occurrence.
  // Content such as a rating or review may change without changing this identity.
  dedupeKey  String?   @unique
  sourceType String
  sourceUri  String?
  loggedAt   DateTime?
  watchedAt  DateTime?
  rating     Float?
  review     String?
  favorite   Boolean   @default(false)
  rewatch    Boolean   @default(false)
  tags       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([watchedAt])
  @@index([movieId])
  @@index([movieId, watchedAt])
  @@index([sourceUri])
  @@index([userId])
  @@index([userId, watchedAt])
}
