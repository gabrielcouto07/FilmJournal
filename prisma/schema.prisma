generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Movie {
  id                    String      @id @default(cuid())
  tmdbId                Int?        @unique
  title                 String
  year                  Int?
  releaseDate           DateTime?
  letterboxdUri         String?     @unique
  posterPath            String?
  backdropPath          String?
  preferredPosterPath   String?
  preferredBackdropPath String?
  overview              String?
  tagline               String?
  runtime               Int?
  genres                String?
  directors             String?
  cast                  String?
  tmdbRating            Float?
  tmdbVoteCount         Int?
  imdbId                String?     @unique
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  logs                  LogEntry[]
  userMovies            UserMovie[]

  @@index([title])
  @@index([year])
}

model User {
  id           String      @id @default(cuid())
  username     String      @unique
  email        String      @unique
  passwordHash String
  displayName  String?
  avatarUrl    String?
  bio          String?
  role         String      @default("USER") // e.g. OWNER, USER
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  userMovies   UserMovie[]
  logs         LogEntry[]
}

model UserMovie {
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId          String
  movie            Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  watched          Boolean   @default(false)
  favorite         Boolean   @default(false)
  favoriteRank     Int?
  watchlist        Boolean   @default(false)
  watchlistAddedAt DateTime?
  rating           Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@id([userId, movieId])
  @@unique([userId, favoriteRank])
  @@index([userId])
  @@index([movieId])
  @@index([watched])
  @@index([favorite])
  @@index([watchlist, watchlistAddedAt])
}

model LogEntry {
  id         String    @id @default(cuid())
  movieId    String
  movie      Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceKey  String    @unique
  // v2 event identity: movie + effective watch day + same-day occurrence.
  // Content such as a rating or review may change without changing this identity.
  dedupeKey  String?   @unique
  sourceType String
  sourceUri  String?
  loggedAt   DateTime?
  watchedAt  DateTime?
  rating     Float?
  review     String?
  favorite   Boolean   @default(false)
  rewatch    Boolean   @default(false)
  tags       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([watchedAt])
  @@index([movieId])
  @@index([movieId, watchedAt])
  @@index([sourceUri])
  @@index([userId])
}
