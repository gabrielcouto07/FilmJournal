{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/GABRIEL.CARDOSO/.local/bin/graphify.EXE hook-guard search"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/GABRIEL.CARDOSO/.local/bin/graphify.EXE hook-guard read --strict"
          }
        ]
      }
    ]
  }
}