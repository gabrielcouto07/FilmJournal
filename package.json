{
  "name": "filmjournal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --import tsx --test tests/letterboxd-import.test.ts tests/diary-dedupe.test.ts tests/palate.test.ts tests/blindspots.test.ts tests/play-hybrid.test.ts tests/timeline.test.ts tests/motifs.test.ts tests/verdict.test.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "import:letterboxd": "tsx scripts/import-letterboxd.ts",
    "import:letterboxd:dry": "tsx scripts/import-letterboxd.ts --dry-run",
    "import:letterboxd:live": "tsx scripts/import-letterboxd.ts --yes",
    "db:dedupe": "tsx scripts/dedupe-letterboxd.ts",
    "db:dedupe:apply": "tsx scripts/dedupe-letterboxd.ts --apply",
    "dedupe:diary": "npm run db:dedupe",
    "dedupe:diary:apply": "npm run db:dedupe:apply",
    "validate:letterboxd": "tsx scripts/validate-letterboxd.ts",
    "typecheck": "tsc --noEmit",
    "backfill:collections": "tsx scripts/backfill-collections.ts",
    "backfill:metadata": "tsx scripts/backfill-metadata.ts",
    "backfill:tmdb:dry": "tsx scripts/backfill-tmdb.ts --dry-run",
    "backfill:tmdb": "tsx scripts/backfill-tmdb.ts",
    "resolve:tmdb:dry": "tsx scripts/resolve-tmdb-ids.ts --dry-run",
    "resolve:tmdb": "tsx scripts/resolve-tmdb-ids.ts",
    "owner:reset": "tsx scripts/reset-owner-password.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "fflate": "^0.8.3",
    "framer-motion": "^12.42.2",
    "next": "^15.0.0",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.20",
    "postcss": "^8.4.49",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
