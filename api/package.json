{
  "name": "filmjournal-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "import:letterboxd": "tsx scripts/import-letterboxd.ts",
    "import:letterboxd:dry": "tsx scripts/import-letterboxd.ts --dry-run",
    "import:letterboxd:live": "tsx scripts/import-letterboxd.ts --yes",
    "db:dedupe": "tsx scripts/dedupe-letterboxd.ts",
    "db:dedupe:apply": "tsx scripts/dedupe-letterboxd.ts --apply",
    "validate:letterboxd": "tsx scripts/validate-letterboxd.ts",
    "backfill:collections": "tsx scripts/backfill-collections.ts",
    "backfill:metadata": "tsx scripts/backfill-metadata.ts",
    "backfill:tmdb:dry": "tsx scripts/backfill-tmdb.ts --dry-run",
    "backfill:tmdb": "tsx scripts/backfill-tmdb.ts",
    "resolve:tmdb:dry": "tsx scripts/resolve-tmdb-ids.ts --dry-run",
    "resolve:tmdb": "tsx scripts/resolve-tmdb-ids.ts",
    "owner:reset": "tsx scripts/reset-owner-password.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@prisma/client": "^6.0.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "fflate": "^0.8.3",
    "jsonwebtoken": "^9.0.2",
    "resend": "^6.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.7",
    "prisma": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
