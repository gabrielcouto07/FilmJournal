generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Movie {
  id                    String      @id @default(cuid())
  tmdbId                Int?        @unique
  title                 String
  year                  Int?
  releaseDate           DateTime?
  letterboxdUri         String?     @unique
  posterPath            String?
  backdropPath          String?
  preferredPosterPath   String?
  preferredBackdropPath String?
  overview              String?
  tagline               String?
  runtime               Int?
  genres                String?
  directors             String?
  directorId            Int?
  directorName          String?
  cast                  String?
  tmdbRating            Float?
  tmdbVoteCount         Int?
  originalLanguage      String? // ISO 639-1, e.g. "ja"
  countries             String[] // ISO 3166-1, e.g. ["JP"]
  imdbId                String?     @unique
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  logs                  LogEntry[]
  userMovies            UserMovie[]
  genreList             Genre[]
  keywords              Keyword[]
  movieLists            MovieListMovie[]

  @@index([title])
  @@index([year])
}

// Gêneros do TMDB ligados aos filmes; o texto antigo continua por compatibilidade.
model Genre {
  id     Int     @id // TMDB genre id
  name   String
  movies Movie[]
}

// Palavras-chave do TMDB usadas na análise de temas recorrentes.
model Keyword {
  id     Int     @id // TMDB keyword id
  name   String
  movies Movie[]
}

model User {
  id                  String               @id @default(cuid())
  username            String               @unique
  email               String               @unique
  passwordHash        String
  displayName         String?
  avatarUrl           String?
  bio                 String?
  role                String               @default("USER") // e.g. OWNER, USER
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  userMovies          UserMovie[]
  logs                LogEntry[]
  settings            UserSettings?
  blindSpotDismissals BlindSpotDismissal[]
  gameScores          GameScore[]
  movieLists          MovieList[]
  pendingPasswordChange PendingPasswordChange?
}

// Troca de senha pendente: guarda o código (hash) enviado por e-mail e a nova
// senha (hash) até o usuário confirmar pelo código. Uma por usuário; expira e
// limita tentativas. Ver /api/account/password e .../password/confirm.
model PendingPasswordChange {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash        String
  newPasswordHash String
  attempts        Int      @default(0)
  expiresAt       DateTime
  createdAt       DateTime @default(now())
}

// Melhor pontuação por modo e fonte do jogo.
model GameScore {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game       String
  source     String
  bestScore  Int
  bestRounds Int
  updatedAt  DateTime @updatedAt

  @@id([userId, game, source])
}

// Preferências ignoradas nos pontos cegos; `*` silencia a dimensão inteira.
model BlindSpotDismissal {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dimension String // "decade" | "country" | "language" | "genre"
  gapKey    String
  createdAt DateTime @default(now())

  @@id([userId, dimension, gapKey])
}

model UserSettings {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme              String   @default("dark") // "system" | "dark" | "light"
  accentColor        String   @default("#f5c518")
  language           String   @default("pt-BR") // "pt-BR" | "en"
  region             String   @default("BR")
  dateFormat         String   @default("dd/MM/yyyy")
  defaultRatingScale Int      @default(5) // 5 | 10
  allowHalfStars     Boolean  @default(true)
  profileVisibility  String   @default("private") // "private" | "public"
  defaultLandingPage String   @default("/")
  emailNotifications Boolean  @default(false)
  // Últimos filtros da roleta, compartilhados entre dispositivos.
  rouletteFilters    Json?
  // `null` indica que a introdução ainda não foi concluída.
  onboardedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model MovieList {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isPublic    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  movies      MovieListMovie[]

  @@index([userId])
}

model MovieListMovie {
  listId   String
  movieId  String
  position Int?
  addedAt  DateTime  @default(now())
  list     MovieList @relation(fields: [listId], references: [id], onDelete: Cascade)
  movie    Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@id([listId, movieId])
  @@index([movieId])
}

model UserMovie {
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId          String
  movie            Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  watched          Boolean   @default(false)
  favorite         Boolean   @default(false)
  favoriteRank     Int?
  watchlist        Boolean   @default(false)
  watchlistAddedAt DateTime?
  rating           Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@id([userId, movieId])
  @@unique([userId, favoriteRank])
  @@index([userId])
  @@index([movieId])
  @@index([userId, watched])
  @@index([userId, watchlist, watchlistAddedAt])
  @@index([userId, rating])
}

// Limites de requisição compartilhados entre instâncias serverless.
model RateLimit {
  key     String   @id
  count   Int      @default(1)
  resetAt DateTime

  @@index([resetAt])
}

model LogEntry {
  id         String    @id @default(cuid())
  movieId    String
  movie      Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceKey  String    @unique
  // Identidade da sessão: filme, dia efetivo e ocorrência no mesmo dia.
  dedupeKey  String?   @unique
  sourceType String
  sourceUri  String?
  loggedAt   DateTime?
  watchedAt  DateTime?
  rating     Float?
  review     String?
  favorite   Boolean   @default(false)
  rewatch    Boolean   @default(false)
  tags       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([watchedAt])
  @@index([movieId])
  @@index([movieId, watchedAt])
  @@index([sourceUri])
  @@index([userId])
  @@index([userId, watchedAt])
}
