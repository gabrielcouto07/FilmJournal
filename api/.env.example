# Postgres (Neon: use a URL com pooler no DATABASE_URL e a direta no DIRECT_URL)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

PORT=4000
# Origem do frontend, separada por vírgula se houver mais de uma (ex.: produção + previews)
CORS_ORIGIN="http://localhost:3000"

# Gere com: openssl rand -base64 32
JWT_SECRET=""
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

APP_OWNER_USERNAME=""
APP_OWNER_PASSWORD=""

TMDB_API_KEY=""

# E-mail (código de confirmação de troca de senha)
RESEND_API_KEY=""
EMAIL_FROM="FilmJournal <onboarding@resend.dev>"
